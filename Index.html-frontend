<!DOCTYPE html>
<html>
<head>
  <title>Pi App</title>
  <script src="https://sdk.minepi.com/pi-sdk.js"></script>
</head>
<body>
  <h1>Pi Network Login</h1>
  <button onclick="doPiAuth()">Sign in with Pi</button>
  <p id="user"></p>

  <script>
    Pi.init({ version: "2.0", sandbox: false, appId: "nftsocial2846" })

    async function doPiAuth() {
      const auth = await Pi.authenticate(['username', 'payments'], onIncompletePaymentFound)
        const res = await fetch('/api/login', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ 
  accessToken: auth.accessToken,
  username: auth.user.username,
  uid: auth.user.uid
})
        const data = await res.json()
        document.getElementById('user').innerText = 'Logged in as: ' + data.user.username
      } catch (e) {
        console.log(e)
      }
    }
function onIncompletePaymentFound(payment) {
  console.log("Payment callback:", payment);
}
    // Auto login pas buka app
    window.onload = doPiAuth
  </script>
</body>
</html>
